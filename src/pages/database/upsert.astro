body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(0,212,255,.05) 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,rgba(255,170,0,.05) 0%,transparent 50%);pointer-events:none;z-index:0}

