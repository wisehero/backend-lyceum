.step-card .step-name{font-size:12px;font-weight:600;margin-bottom:2px}
.step-card .step-time{font-family:var(--font-mono);font-size:11px;color:var(--text-dim)}
.step-card.slow{border-color:var(--red-dim);color:var(--red)}
.step-card.slow .step-num{color:var(--red)}
.step-card.mid{border-color:var(--amber-dim);color:var(--amber)}
.step-card.mid .step-num{color:var(--amber)}
.step-card.fast{border-color:var(--green-dim);color:var(--green)}
.step-card.fast .step-num{color:var(--green)}

/* ── INDEX DIAGRAM ── */
.idx-diagram{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r-xl);padding:22px;position:relative;overflow:hidden}
.idx-row{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.idx-node{min-width:50px;min-height:36px;padding:6px 10px;border-radius:var(--r-sm);font-size:11px;font-weight:600;text-align:center;font-family:var(--font-mono);border:1px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center}
.idx-node.leaf{border-color:var(--green-dim);color:var(--green);background:var(--green-pale)}
.idx-node.page{border-color:var(--red-dim);color:var(--red);background:var(--red-pale)}
.idx-node.pk{border-color:var(--cyan-dim);color:var(--cyan);background:var(--cyan-pale)}
.jump-arrow{color:var(--red);font-family:var(--font-mono);font-size:16px;font-weight:700}
.flow-arrow{color:var(--green);font-family:var(--font-mono);font-size:16px;font-weight:700}

/* ── CHECKLIST ── */
.check-item{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r-md);padding:14px 18px;display:flex;align-items:flex-start;gap:12px;transition:all .3s;margin-bottom:8px}
.check-item:hover{border-color:var(--cyan-dim);transform:translateX(4px)}
.check-icon{width:24px;min-height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--green-pale);border:1px solid var(--green-dim)}
.check-icon svg{width:14px;height:14px;color:var(--green)}
.check-text{font-size:15px;color:var(--text-sec);line-height:1.7}
.check-text strong{color:var(--text)}

/* ── QUOTE BOX ── */
.quote-box{background:var(--bg-card);border-left:3px solid var(--cyan);border-radius:0 var(--r-lg) var(--r-lg) 0;padding:18px 22px;margin:18px 0;font-size:14px;color:var(--text-sec);line-height:1.9;font-style:italic}
.quote-box strong{color:var(--cyan);font-style:normal}

/* ── WAL DIAGRAM ── */
.wal-flow{display:flex;align-items:center;justify-content:center;gap:8px;margin:14px 0;flex-wrap:wrap}
.wal-node{min-width:80px;min-height:56px;padding:10px 14px;border-radius:var(--r-md);display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:12px;font-weight:600;gap:4px;border:1px solid var(--border);background:var(--surface)}
.wal-node svg{width:20px;height:20px}
.wal-node.wr{border-color:var(--green-dim);color:var(--green);background:var(--green-pale)}
.wal-node.log{border-color:var(--amber-dim);color:var(--amber);background:var(--amber-pale)}
.wal-node.db{border-color:rgba(124,58,237,.3);color:#c4b5fd;background:rgba(124,58,237,.12)}
.wal-arr{font-family:var(--font-mono);font-size:14px;color:var(--text-dim);font-weight:700}

/* ── RESPONSIVE ── */
@media(max-width:768px){.g2,.g3,.g4{grid-template-columns:1fr}.hdd-parts{flex-direction:column;align-items:center}.step-row{flex-direction:column;align-items:center}.io-viz{padding:14px}.block-row{gap:4px}.blk{width:34px;min-height:34px;font-size:9px}}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}
</style>

<script>
// ── I/O Pattern Animation (comparison section) ──
let seqAnim=null,rndAnim=null;
function animateSeq(){
  const blks=document.querySelectorAll('#seqBlocks .blk');
  let i=0;
  if(seqAnim)clearInterval(seqAnim);
  blks.forEach(b=>b.classList.remove('hi'));
  seqAnim=setInterval(()=>{
    blks.forEach(b=>b.classList.remove('hi'));
    if(i<blks.length){blks[i].classList.add('hi');i++}
    else{i=0}
  },400);
}
function animateRnd(){
  const blks=document.querySelectorAll('#rndBlocks .blk.rnd');
  const order=[2,0,3,1];
  let i=0;
  if(rndAnim)clearInterval(rndAnim);
  blks.forEach(b=>b.classList.remove('hi'));
  rndAnim=setInterval(()=>{
    blks.forEach(b=>b.classList.remove('hi'));
    if(i<order.length){blks[order[i]].classList.add('hi');i++}
    else{i=0}
  },600);
}

// Start animations when comparison section is visible
const compSection=document.getElementById('comparison');
if(compSection){
  const obs=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){animateSeq();animateRnd()}
      else{
        if(seqAnim)clearInterval(seqAnim);
        if(rndAnim)clearInterval(rndAnim);
        document.querySelectorAll('#seqBlocks .blk, #rndBlocks .blk').forEach(b=>b.classList.remove('hi'));
      }
    });
  },{threshold:0.3});
  obs.observe(compSection);
}
</script>
