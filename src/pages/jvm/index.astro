---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { categories } from '../../data/categories';
const cat = categories.find(c => c.key === 'jvm')!;
---

<CategoryLayout title={cat.name} categoryKey={cat.key} accentColor={cat.accentColor} lectures={cat.lectures}>
  <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
    <line x1="8" y1="21" x2="16" y2="21"/>
    <line x1="12" y1="17" x2="12" y2="21"/>
  </svg>
</CategoryLayout>
