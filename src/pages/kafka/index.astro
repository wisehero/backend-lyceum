---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { categories } from '../../data/categories';
const cat = categories.find(c => c.key === 'kafka')!;
---

<CategoryLayout title={cat.name} subtitle="메시지 큐, 트랜잭션 아웃박스, 이벤트 드리븐 아키텍처" categoryKey={cat.key} accentColor={cat.accentColor} lectures={cat.lectures}>
  <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
  </svg>
</CategoryLayout>
