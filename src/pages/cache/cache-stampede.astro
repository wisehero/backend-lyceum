<script>
const $=id=>document.getElementById(id);

// ── STAMPEDE VISUALIZER ──
let svRun=false,svTtl=60,svInt=null,svTimers=[];
function svReset(){
  if(svInt){clearInterval(svInt);svInt=null}
  svTimers.forEach(t=>clearTimeout(t));svTimers=[];
  svRun=false;svTtl=60;
  $('svFill').style.width='100%';$('svFill').className='sv-gauge-fill';
  $('svVal').textContent='60s';$('svVal').className='sv-gauge-val ok';
  $('svStat').textContent='NORMAL';$('svStat').className='sv-status ok';
  $('svDb').className='sv-db-box ok';$('svImpact').classList.remove('vis');
  $('svLog').innerHTML='[ READY ] Press play to simulate the Stampede';
  for(let i=0;i<4;i++){
    $('svC'+i).classList.remove('rush');
    $('svA'+i).classList.remove('vis');
    $('svAL'+i).classList.remove('rush');
    $('svAT'+i).classList.remove('rush');
    const d=$('svAD'+i);d.classList.remove('run');d.style.opacity='0';d.style.left='0';
  }
}
function svPlay(){
  if(svRun)return;svReset();svRun=true;
  $('svLog').innerHTML='[ <span class="hl-g">MONITORING</span> ] TTL countdown in progress...';
  svInt=setInterval(()=>{
    svTtl--;
    const p=svTtl/60*100;
    $('svFill').style.width=p+'%';
    $('svFill').className='sv-gauge-fill'+(p<25?' low':p<50?' mid':'');
    $('svVal').textContent=svTtl+'s';
    $('svVal').className='sv-gauge-val'+(svTtl<15?' crit':svTtl<30?' warn':' ok');
    if(svTtl<=15){$('svStat').textContent='WARNING';$('svStat').className='sv-status danger'}
    if(svTtl<=0){clearInterval(svInt);svInt=null;svHit()}
  },80);
}
function svHit(){
  $('svFill').style.width='0%';$('svFill').className='sv-gauge-fill dead';
  $('svVal').textContent='EXPIRED';$('svVal').className='sv-gauge-val crit';
  $('svStat').textContent='DANGER';$('svStat').className='sv-status danger';
  $('svLog').innerHTML='[ <span class="hl-r">ALERT</span> ] Cache MISS — All requests heading to DB!';

  svTimers.push(setTimeout(()=>{
    const delays=[0,100,180,280];
    delays.forEach((d,i)=>{
      svTimers.push(setTimeout(()=>{
        $('svC'+i).classList.add('rush');
        $('svA'+i).classList.add('vis');
        $('svAL'+i).classList.add('rush');
        $('svAT'+i).classList.add('rush');
        const dot=$('svAD'+i);dot.classList.remove('run');void dot.offsetWidth;dot.classList.add('run');
      },d));
    });
    svTimers.push(setTimeout(()=>{
      $('svDb').className='sv-db-box stressed';
      $('svImpact').classList.add('vis');
      $('svLog').innerHTML='[ <span class="hl-r">DANGER</span> ] DB overload — N concurrent queries exploding!';
    },600));
    svTimers.push(setTimeout(()=>{
      $('svLog').innerHTML='[ <span class="hl-r">ROOT CAUSE</span> ] Only 1 DB trip needed, but there is no coordination mechanism';
      svRun=false;
    },2500));
  },300));
}

// ── MUTEX FLOW ──
let mxS=0,mxAuto=null;
const mxClasses=['lit','lit','lit-red','lit-green','lit-green'];
function mxClr(){for(let i=0;i<5;i++)$('mx'+i).className='sf-step';mxS=0}
function mxDoStep(){
  if(mxS>=5){mxClr();return}
  $('mx'+mxS).classList.add(mxClasses[mxS]);
  mxS++;
}
function mxStep(){if(mxAuto){clearInterval(mxAuto);mxAuto=null}mxDoStep()}
function mxPlay(){mxClr();if(mxAuto){clearInterval(mxAuto);mxAuto=null}mxAuto=setInterval(()=>{if(mxS>=5){clearInterval(mxAuto);mxAuto=null;return}mxDoStep()},1200)}
function mxReset(){if(mxAuto){clearInterval(mxAuto);mxAuto=null}mxClr()}

// ── PROACTIVE TIMELINE ──
let tlAnim=null,tlStep=0;
function tlReset(){if(tlAnim){clearInterval(tlAnim);tlAnim=null}tlStep=0;
  for(let i=0;i<3;i++){const s=$('tlSeg'+i);s.className='tl-segment'+(i===0?' filled':'')}
  $('tlLog').innerHTML='[ INFO ] Cache always has data → <span class="hl-g">Stampede probability = 0</span>'}
function tlPlay(){tlReset();
  tlAnim=setInterval(()=>{
    const seg=$('tlSeg'+tlStep);
    seg.classList.add('filled');
    $('tlLog').innerHTML='[ <span class="hl-g">REFRESH</span> ] Segment '+(tlStep+1)+' — Scheduler refreshed before TTL expiry';
    tlStep++;
    if(tlStep>=3){clearInterval(tlAnim);tlAnim=null;
      setTimeout(()=>{$('tlLog').innerHTML='[ <span class="hl-g">RESULT</span> ] Cache always has data → Stampede probability = 0'},800)}
  },1200);
}
</script>
