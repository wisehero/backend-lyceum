---
import { categories } from '../data/categories';

interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;
---

<header class="header-root">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
      <span class="logo-text">DEV <span class="logo-accent">LYCEUM</span></span>
    </a>

    <!-- Desktop Category Nav -->
    <nav class="header-nav">
      {categories.map((cat, i) => (
        <>
          <a
            href={cat.href}
            class:list={['nav-item', activeCategory === cat.key && 'active']}
          >
            {cat.name}
          </a>
          {i < categories.length - 1 && <span class="nav-divider" />}
        </>
      ))}
    </nav>

    <!-- Right: Theme Toggle + Hamburger -->
    <div class="header-right">
      <button id="theme-toggle" class="header-btn" aria-label="테마 전환">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button id="menu-toggle" class="header-btn menu-btn" aria-label="메뉴">
        <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Tablet: scrollable nav (640px ~ 900px) -->
  <nav class="header-nav-tablet">
    {categories.map((cat, i) => (
      <>
        <a
          href={cat.href}
          class:list={['nav-item', activeCategory === cat.key && 'active']}
        >
          {cat.name}
        </a>
        {i < categories.length - 1 && <span class="nav-divider" />}
      </>
    ))}
  </nav>

</header>

<!-- Mobile: fullscreen overlay menu (<640px) — outside header to avoid stacking context -->
<div class="mobile-overlay" id="mobile-overlay">
  <nav class="mobile-menu">
    {categories.map((cat) => (
      <a
        href={cat.href}
        class:list={['mobile-nav-item', activeCategory === cat.key && 'active']}
      >
        {cat.name}
      </a>
    ))}
  </nav>
</div>

<style>
  .header-root {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(16px);
    background: color-mix(in srgb, var(--bg) 90%, transparent);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  /* Logo */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--cyan-pale);
    border: 1px solid var(--cyan-dim);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-icon svg {
    width: 15px;
    height: 15px;
    color: var(--cyan);
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.3px;
  }
  .logo-accent {
    color: var(--cyan);
  }

  /* Desktop Nav (900px+) */
  .header-nav {
    flex: 1;
    display: none;
    align-items: center;
    gap: 4px;
    justify-content: center;
  }
  @media (min-width: 900px) {
    .header-nav { display: flex; }
  }

  .nav-item {
    padding: 6px 12px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .nav-item:hover {
    background: var(--surface);
  }
  .nav-item.active {
    font-weight: 700;
    background: var(--surface);
  }

  .nav-divider {
    width: 1px;
    height: 16px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Right buttons */
  .header-right {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .header-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    color: var(--text);
    flex-shrink: 0;
  }
  .header-btn:hover {
    border-color: var(--cyan-dim);
    color: var(--cyan);
  }
  .header-btn svg {
    width: 16px;
    height: 16px;
  }

  /* Theme icons */
  :global(.dark) .icon-sun { display: block; }
  :global(.dark) .icon-moon { display: none; }
  .icon-sun { display: none; }
  .icon-moon { display: block; }

  /* Hamburger: only show below 640px */
  .menu-btn { display: none; }
  .icon-close { display: none; }
  @media (max-width: 640px) {
    .menu-btn { display: flex; }
  }
  :global(.menu-open) .icon-menu { display: none; }
  :global(.menu-open) .icon-close { display: block; }

  /* Tablet Nav (640px ~ 900px) */
  .header-nav-tablet {
    display: none;
    align-items: center;
    gap: 4px;
    padding: 0 16px 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .header-nav-tablet::-webkit-scrollbar { display: none; }
  .header-nav-tablet .nav-item {
    font-size: 11px;
    padding: 4px 8px;
  }
  .header-nav-tablet .nav-divider {
    height: 12px;
  }
  @media (min-width: 641px) and (max-width: 899px) {
    .header-nav-tablet { display: flex; }
  }

  /* Mobile Overlay (<640px) */
  .mobile-overlay {
    position: fixed;
    top: 57px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    padding: 24px 20px;
    overflow-y: auto;
    background: var(--bg);
    pointer-events: none;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.2s, visibility 0.2s;
  }
  .mobile-overlay.open {
    pointer-events: all;
    visibility: visible;
    opacity: 1;
  }
  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mobile-nav-item {
    display: block;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    border-radius: 10px;
    transition: background 0.2s;
  }
  .mobile-nav-item:hover,
  .mobile-nav-item.active {
    background: var(--surface);
    font-weight: 700;
  }

  /* Mobile: hide logo text */
  @media (max-width: 400px) {
    .logo-text { display: none; }
  }
</style>

<script is:inline>
  (function() {
    if (window.__headerInit) return;
    window.__headerInit = true;

    document.addEventListener('click', function(e) {
      // Theme toggle
      var btn = e.target.closest('#theme-toggle');
      if (btn) {
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        if (isDark) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        return;
      }

      // Hamburger toggle
      var menuBtn = e.target.closest('#menu-toggle');
      if (menuBtn) {
        var overlay = document.getElementById('mobile-overlay');
        var isOpen = overlay.classList.contains('open');
        if (isOpen) {
          overlay.classList.remove('open');
          document.body.classList.remove('menu-open');
          document.body.style.overflow = '';
        } else {
          overlay.classList.add('open');
          document.body.classList.add('menu-open');
          document.body.style.overflow = 'hidden';
        }
        return;
      }

      // Close menu on nav item click
      var navItem = e.target.closest('.mobile-nav-item');
      if (navItem) {
        var ov = document.getElementById('mobile-overlay');
        if (ov) ov.classList.remove('open');
        document.body.classList.remove('menu-open');
        document.body.style.overflow = '';
      }
    });

    // Close menu on resize to desktop
    window.addEventListener('resize', function() {
      if (window.innerWidth > 640) {
        var ov = document.getElementById('mobile-overlay');
        if (ov) ov.classList.remove('open');
        document.body.classList.remove('menu-open');
        document.body.style.overflow = '';
      }
    });
  })();
</script>
